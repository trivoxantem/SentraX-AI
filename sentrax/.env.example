# ============================================================
# SentraX Django Backend - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================================
# ENVIRONMENT CONFIGURATION
# ============================================================
# Set to 'production' for Render deployment
ENVIRONMENT=development

# Django Settings
DEBUG=True
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# For development (SQLite is used by default)
# For production on Render, this will be auto-generated

# PostgreSQL Database URL for production
# Format: postgresql://username:password@host:port/dbname
# Example: postgresql://user:password@localhost:5432/sentrax
DATABASE_URL=

# ============================================================
# ALLOWED HOSTS
# ============================================================
# Comma-separated list of allowed hosts
# For development:
ALLOWED_HOSTS=localhost,127.0.0.1

# For production (example):
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com

# ============================================================
# CORS SETTINGS
# ============================================================
# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# ============================================================
# SECURITY SETTINGS
# ============================================================
# For production, set to True (Render uses HTTPS)
SECURE_SSL_REDIRECT=False

# ============================================================
# THREAT INTELLIGENCE API KEYS
# ============================================================
# Google Safe Browsing API Key
# Get from: https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_API_KEY=your-google-safe-browsing-api-key

# PhishTank API Key (Optional)
# Get from: https://www.phishtank.com/api_info.php
PHISHTANK_API_KEY=

# ============================================================
# DJANGO SECRET KEY GENERATION
# ============================================================
# To generate a new SECRET_KEY, run:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'

# ============================================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================================
# 1. Change ENVIRONMENT to 'production'
# 2. Set a strong SECRET_KEY
# 3. Set DEBUG to False
# 4. Configure ALLOWED_HOSTS with your domain
# 5. Set up PostgreSQL and provide DATABASE_URL
# 6. Set FRONTEND_URL to your frontend domain
# 7. Set SECURE_SSL_REDIRECT to True
# 8. Add API keys for threat intelligence services
